<template>
  <view class="page">
    <view class="hero">
      <image class="brand-logo" src="/static/app-logo.png" mode="aspectFit"></image>
      <text class="eyebrow">Image Repair</text>
      <text class="summary">上传一张或多张图片，让 AI 自动处理水印和明显瑕疵。</text>
    </view>

    <view class="upload-box" hover-class="upload-box-hover" @click="chooseImage">
      <view class="upload-icon">
        <text class="upload-plus">+</text>
      </view>
      <text class="upload-title">点击添加图片</text>
      <text class="upload-desc">支持批量选择，单次最多 9 张，建议单张不超过 10MB</text>
    </view>

    <label class="notice" @click="toggleAgree">
      <view class="checkbox" :class="{ checked: agreed }"></view>
      <text class="notice-text">我确认拥有所选图片的合法使用权，并同意仅将本工具用于授权图片修复。</text>
    </label>

    <button class="primary" type="primary" @click="chooseImage">选择图片</button>
  </view>
</template>

<script lang="uts">
  export default {
    data() {
      return {
        // 用户必须确认图片授权后才能进入批量修复流程。
        agreed: false
      }
    },
    methods: {
      toggleAgree() {
        this.agreed = !this.agreed
      },
      encodePaths(paths: string[]): string {
        // 使用 encodeURIComponent + 分隔符存储，避免本地路径中的特殊字符破坏页面传参。
        const encoded: string[] = []
        for (let i = 0; i < paths.length; i++) {
          encoded.push(encodeURIComponent(paths[i]) as string)
        }
        return encoded.join('|')
      },
      chooseImage() {
        if (!this.agreed) {
          uni.showToast({ title: '请先确认图片使用授权', icon: 'none' })
          return
        }

        uni.chooseImage({
          count: 9,
          sizeType: ['compressed'],
          sourceType: ['album', 'camera'],
          success: (res) => {
            const paths = res.tempFilePaths
            if (paths.length == 0) {
              uni.showToast({ title: '未选择图片', icon: 'none' })
              return
            }
            // 批量图片路径可能较长，放入本地缓存后再跳转编辑页读取。
            uni.setStorageSync('repair_batch_sources', this.encodePaths(paths))
            uni.navigateTo({
              url: '/pages/editor/editor?batch=1'
            })
          },
          fail: () => {
            uni.showToast({ title: '未选择图片', icon: 'none' })
          }
        })
      }
    }
  }
</script>

